---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";

const projects = (await getCollection("projects"))
  .filter(({ data }) => data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);

const publications = (await getCollection("publications"))
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 3);

const notes = (await getCollection("notes"))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<BaseLayout title="Zhiyu Zheng | VLSI Physical Design and EDA Tooling" description={site.defaultDescription}>
  <section class="hero panel">
    <div class="hero-copy">
      <div class="hero-intro">
        <span class="eyebrow">Research + Engineering</span>
        <h1>{site.preferredDisplayName}</h1>
        <p class="hero-title">{site.title}</p>
      </div>
      <div class="prose">
        {site.heroBio.map((paragraph) => <p>{paragraph}</p>)}
      </div>
      <div class="hero-meta">
        <span>{site.affiliation}</span>
        <span>{site.currentRole}</span>
        <span>{site.location}</span>
      </div>
      <div class="cta-row">
        <a class="button primary" href={`mailto:${site.emailPrimary}`}>Email</a>
        <a class="button" href={site.github} target="_blank" rel="noreferrer">GitHub</a>
        <a class="button" href="/publications">Publications</a>
        <a class="button" href="/cv">CV</a>
      </div>
    </div>
    <div class="hero-aside">
      <div class="hero-card">
        <span class="eyebrow">Current Focus</span>
        <ul class="list compact">
          <li>Open-source EDA tooling and flow engineering</li>
          <li>Macro placement and physical-design optimization</li>
          <li>3D IC implementation and benchmark-oriented evaluation</li>
          <li>Reproducible infrastructure for academic CAD experiments</li>
        </ul>
      </div>
      <div class="hero-card">
        <span class="eyebrow">Profile</span>
        <ul class="list compact">
          <li><a class="inline-link" href={site.github} target="_blank" rel="noreferrer">GitHub / shifengzhicheng</a></li>
          <li><a class="inline-link" href={site.gitee} target="_blank" rel="noreferrer">Gitee / Maple_of_Ten</a></li>
          <li>Google Scholar / TODO</li>
          <li>CV PDF / TODO</li>
        </ul>
      </div>
    </div>
  </section>

  <section>
    <div class="section-header">
      <div>
        <span class="eyebrow">Research Interests</span>
        <h2 class="section-title">Research Areas</h2>
      </div>
    </div>
    <ul class="chip-list">
      {site.researchInterests.map((item) => <li>{item}</li>)}
    </ul>
  </section>

  <section>
    <div class="section-header">
      <div>
        <span class="eyebrow">Selected Projects</span>
        <h2 class="section-title">Selected Research and Tooling Projects</h2>
      </div>
      <a class="inline-link" href="/projects">View all projects</a>
    </div>
    <div class="grid cards-2">
      {projects.map((project) => (
        <article class="card">
          <h3>{project.data.title}</h3>
          <p>{project.data.summary}</p>
          <div class="meta">
            <span>{project.data.type}</span>
            {project.data.role && <span>{project.data.role}</span>}
            {project.data.repo && (
              <a href={project.data.repo} target="_blank" rel="noreferrer">Repository</a>
            )}
            {project.data.link && <span>{project.data.link}</span>}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section>
    <div class="section-header">
      <div>
        <span class="eyebrow">Publications</span>
        <h2 class="section-title">Selected Publications</h2>
      </div>
      <a class="inline-link" href="/publications">Full list</a>
    </div>
    <div class="grid">
      {publications.map((publication) => (
        <article class="card">
          <h3>{publication.data.title}</h3>
          <p>{publication.data.authors}</p>
          <div class="meta">
            <span>{publication.data.venue}</span>
            <span>{publication.data.year}</span>
            <span>{publication.data.type}</span>
            {publication.data.doiOrLink && (
              <a href={publication.data.doiOrLink} target="_blank" rel="noreferrer">DOI</a>
            )}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section>
    <div class="section-header">
      <div>
        <span class="eyebrow">Recent Notes</span>
        <h2 class="section-title">Notes on Flows, Tooling, and Experiments</h2>
      </div>
      <a class="inline-link" href="/notes">All notes</a>
    </div>
    <div class="grid cards-3">
      {notes.map((note) => (
        <article class="card">
          <h3><a href={`/notes/${note.slug}/`}>{note.data.title}</a></h3>
          <p>{note.data.summary}</p>
          <div class="meta">
            <span>{note.data.date.toISOString().slice(0, 10)}</span>
            {note.data.draft && <span>Draft</span>}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section>
    <div class="section-header">
      <div>
        <span class="eyebrow">Contact</span>
        <h2 class="section-title">Contact</h2>
      </div>
    </div>
    <div class="card prose">
      <p>
        Email is the primary public contact channel: <a class="inline-link" href={`mailto:${site.emailPrimary}`}>{site.emailPrimary}</a>.
        The secondary institutional address remains hidden until verified. QR code and CV PDF are intentionally left as TODO placeholders for later publication.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.7fr) minmax(300px, 0.9fr);
    gap: 1.5rem;
    padding: 1.75rem;
    min-height: calc(100vh - 8rem);
    align-items: end;
  }

  .hero-copy {
    padding: 0.25rem;
  }

  h1 {
    margin: 0.5rem 0 0;
    font-family: var(--font-serif);
    font-size: clamp(3rem, 7vw, 6rem);
    line-height: 0.95;
    letter-spacing: -0.03em;
  }

  .hero-title {
    margin: 1rem 0 0;
    max-width: 24ch;
    font-size: clamp(1.15rem, 2vw, 1.55rem);
    color: var(--muted);
    line-height: 1.5;
  }

  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .hero-meta span {
    padding: 0.55rem 0.8rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.52);
    color: var(--muted);
    font-size: 0.92rem;
  }

  .hero-aside {
    display: grid;
    gap: 1rem;
  }

  .hero-card {
    padding: 1.3rem;
    border-radius: 24px;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.56);
  }

  .compact li {
    color: var(--muted);
    line-height: 1.7;
  }

  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      min-height: auto;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding: 1.15rem;
    }
  }
</style>
