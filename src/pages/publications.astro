---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const publications = (await getCollection("publications")).sort((a, b) => b.data.year - a.data.year);
---

<BaseLayout title="Publications | Zhiyu Zheng">
  <section>
    <div class="section-header">
      <div>
        <span class="eyebrow">Publications</span>
        <h1 class="section-title">Research Output</h1>
      </div>
    </div>
    <div class="grid">
      {publications.map((publication) => (
        <article class="card">
          <h2>{publication.data.title}</h2>
          <p>{publication.data.authors}</p>
          <div class="meta">
            <span>{publication.data.venue}</span>
            <span>{publication.data.year}</span>
            <span>{publication.data.type}</span>
            {publication.data.note && <span>{publication.data.note}</span>}
            {publication.data.doiOrLink && (
              <a href={publication.data.doiOrLink} target="_blank" rel="noreferrer">Open link</a>
            )}
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
