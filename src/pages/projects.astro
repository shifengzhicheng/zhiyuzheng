---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const projects = (await getCollection("projects")).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Projects | Zhiyu Zheng">
  <section>
    <div class="section-header">
      <div>
        <span class="eyebrow">Projects</span>
        <h1 class="section-title">Selected Open-Source, Flow, and CAD Work</h1>
      </div>
    </div>
    <p class="section-copy prose">
      This page emphasizes research and engineering work aligned with VLSI physical design, EDA tooling, reproducible CAD flows, and 3D IC implementation. Earlier or peripheral projects are kept, but they do not define the homepage narrative.
    </p>
    <div class="grid cards-2">
      {projects.map((project) => (
        <article class="card">
          <h2>{project.data.title}</h2>
          <p>{project.data.summary}</p>
          <div class="meta">
            <span>{project.data.type}</span>
            {project.data.role && <span>{project.data.role}</span>}
            {project.data.status && <span>{project.data.status}</span>}
            {project.data.repo && (
              <a href={project.data.repo} target="_blank" rel="noreferrer">Repository</a>
            )}
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
