---
import "../styles/global.css";
import { navigation, site } from "../data/site";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = `${site.preferredDisplayName} | Research + Engineering`,
  description = site.defaultDescription,
  image = site.ogImage
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(image, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title={`${site.preferredDisplayName} RSS`} href={new URL("/rss.xml", Astro.site)} />
    <meta name="robots" content="index,follow" />
    <meta property="og:site_name" content={site.preferredDisplayName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="shell">
        <a class="brand" href="/">
          <span>{site.preferredDisplayName}</span>
          <small>{site.affiliation}</small>
        </a>
        <nav aria-label="Primary">
          <ul>
            {navigation.map((item) => (
              <li><a href={item.href}>{item.label}</a></li>
            ))}
          </ul>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="shell footer-shell">
        <div>
          <strong>{site.preferredDisplayName}</strong>
          <p class="muted">Research-engineering site on VLSI physical design, EDA tooling, and reproducible CAD flows.</p>
        </div>
        <div class="footer-links">
          <a href={`mailto:${site.emailPrimary}`}>Email</a>
          <a href={site.github} target="_blank" rel="noreferrer">GitHub</a>
          <a href="/publications">Publications</a>
          <a href="/cv">CV</a>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    backdrop-filter: blur(18px);
    background: rgba(243, 241, 235, 0.72);
    border-bottom: 1px solid rgba(24, 32, 30, 0.08);
  }

  .shell {
    width: min(calc(100% - 2rem), var(--max-width));
    margin: 0 auto;
  }

  .site-header .shell {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 4.5rem;
  }

  .brand {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .brand span {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-weight: 600;
  }

  .brand small {
    color: var(--muted);
    font-size: 0.84rem;
  }

  nav ul {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  nav a {
    color: var(--muted);
    font-size: 0.95rem;
  }

  .site-footer {
    padding: 0 0 2rem;
  }

  .footer-shell {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 1.5rem 1.75rem;
    border: 1px solid var(--line);
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.62);
    box-shadow: var(--shadow);
  }

  .site-footer p {
    margin: 0.45rem 0 0;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  @media (max-width: 720px) {
    .site-header .shell,
    .footer-shell {
      flex-direction: column;
      align-items: flex-start;
    }

    .shell {
      width: min(calc(100% - 1rem), var(--max-width));
    }
  }
</style>
